<!DOCTYPE html>
<html lang="sw">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enkro Marketplace</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f5f5f5;
        }

        /* HEADER */
        header {
            background: #ff6a00;
            padding: 15px;
            color: white;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .logo {
            font-size: 22px;
            font-weight: bold;
        }

        .search-box input {
            width: 300px;
            padding: 8px;
            border: none;
            border-radius: 4px;
        }

        /* CATEGORIES */
        .categories {
            display: flex;
            gap: 10px;
            padding: 15px;
            background: white;
            overflow-x: auto;
        }

        .cat {
            padding: 8px 12px;
            background: #eee;
            border-radius: 20px;
            white-space: nowrap;
            cursor: pointer;
        }

        /* HERO */
        .hero {
            background: url('https://via.placeholder.com/1200x300') center/cover;
            height: 300px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 30px;
            font-weight: bold;
        }

        /* PRODUCTS */
        .products {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            padding: 20px;
        }

        .card {
            background: white;
            padding: 10px;
            border-radius: 8px;
        }

        .card img {
            width: 100%;
            height: 150px;
            object-fit: cover;
        }

        .price {
            color: green;
            font-weight: bold;
        }

        /* FOOTER */
        footer {
            background: #222;
            color: white;
            text-align: center;
            padding: 15px;
            margin-top: 20px;
        }

    </style>
</head>

<body>

<!-- HEADER -->
<header>
    <div class="logo">Enkro Market</div>

    <div class="search-box">
        <input type="text" placeholder="Tafuta bidhaa...">
    </div>

    <div>
        <button>Login</button>
        <button>Cart</button>
    </div>
</header>

<!-- CATEGORIES -->
<div class="categories">
    <div class="cat">Electronics</div>
    <div class="cat">Fashion</div>
    <div class="cat">Phones</div>
    <div class="cat">Home</div>
    <div class="cat">Beauty</div>
    <div class="cat">Sports</div>
</div>

<!-- HERO SECTION -->
<div class="hero">
    Karibu Enkro Marketplace
</div>

<!-- PRODUCTS -->
<div class="products">

    <div class="card">
        <img src="https://via.placeholder.com/200" alt="">
        <h4>Smartphone</h4>
        <p class="price">Tsh 450,000</p>
    </div>

    <div class="card">
        <img src="https://via.placeholder.com/200" alt="">
        <h4>Laptop</h4>
        <p class="price">Tsh 1,200,000</p>
    </div>

    <div class="card">
        <img src="https://via.placeholder.com/200" alt="">
        <h4>Shoes</h4>
        <p class="price">Tsh 80,000</p>
    </div>

    <div class="card">
        <img src="https://via.placeholder.com/200" alt="">
        <h4>Watch</h4>
        <p class="price">Tsh 120,000</p>
    </div>

</div>

<!-- FOOTER -->
<footer>
    © 2026 Enkro Marketplace - All Rights Reserved
</footer>

</body>
</html>
